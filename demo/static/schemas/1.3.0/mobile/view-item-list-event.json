{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tracking-docs-demo.buchert.digital/schemas/1.3.0/mobile/view-item-list-event.json",
  "title": "View Item List",
  "description": "Triggered when a user views an item list.",
  "x-tracking-targets": [
    "android-firebase-kotlin-sdk",
    "android-firebase-java-sdk",
    "ios-firebase-swift-sdk",
    "ios-firebase-objc-sdk"
  ],
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Defines the structure of the event.",
      "const": "https://tracking-docs-demo.buchert.digital/schemas/mobile/events/view-item-list-event.json"
    },
    "event": {
      "type": "string",
      "const": "view_item_list",
      "description": "The event name view_item_list."
    },
    "item_list_id": {
      "type": "string",
      "description": "ID of the item list.",
      "examples": ["related_products"]
    },
    "item_list_name": {
      "type": "string",
      "description": "Name of the item list.",
      "examples": ["Related Products"]
    },
    "items": {
      "$ref": "../components/items.json"
    }
  },
  "required": ["$schema", "event", "items"]
}
