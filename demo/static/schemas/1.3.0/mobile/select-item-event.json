{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tracking-docs-demo.buchert.digital/schemas/1.3.0/mobile/select-item-event.json",
  "title": "Select Item",
  "description": "Triggered when a user selects an item from a list.",
  "x-tracking-targets": [
    "android-firebase-kotlin-sdk",
    "android-firebase-java-sdk",
    "ios-firebase-swift-sdk",
    "ios-firebase-objc-sdk"
  ],
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Defines the structure of the event.",
      "const": "https://tracking-docs-demo.buchert.digital/schemas/mobile/events/select-item-event.json"
    },
    "event": {
      "type": "string",
      "const": "select_item",
      "description": "The event name select_item."
    },
    "item_list_id": {
      "type": "string",
      "description": "ID of the item list.",
      "examples": ["related_products"]
    },
    "item_list_name": {
      "type": "string",
      "description": "Name of the item list.",
      "examples": ["Related Products"]
    },
    "items": {
      "$ref": "../components/items.json"
    }
  },
  "required": ["$schema", "event", "items"],
  "allOf": [
    {
      "$ref": "https://tracking-docs-demo.buchert.digital/constraints/schemas/firebase/v1/flat-event-params.json"
    }
  ]
}
