{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tracking-docs-demo.buchert.digital/schemas/mobile/refund-event.json",
  "title": "Refund",
  "description": "Triggered when a refund is issued.",
  "x-tracking-targets": [
    "android-firebase-kotlin-sdk",
    "android-firebase-java-sdk",
    "ios-firebase-swift-sdk",
    "ios-firebase-objc-sdk"
  ],
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Defines the structure of the event.",
      "const": "https://tracking-docs-demo.buchert.digital/schemas/mobile/events/refund-event.json"
    },
    "event": {
      "type": "string",
      "const": "refund",
      "description": "The event name refund."
    },
    "transaction_id": {
      "type": "string",
      "description": "Unique transaction identifier.",
      "examples": ["T_12345"]
    },
    "currency": {
      "type": "string",
      "description": "ISO 4217 currency code.",
      "minLength": 3,
      "maxLength": 3,
      "examples": ["USD"]
    },
    "value": {
      "type": "number",
      "description": "Monetary value of the event.",
      "examples": [72.05]
    },
    "coupon": {
      "type": "string",
      "description": "Coupon code associated with the event.",
      "examples": ["SUMMER_FUN"]
    },
    "shipping": {
      "type": "number",
      "description": "Shipping cost for the event.",
      "examples": [5.99]
    },
    "tax": {
      "type": "number",
      "description": "Tax amount for the event.",
      "examples": [3.6]
    },
    "items": {
      "$ref": "../components/items.json"
    }
  },
  "required": ["$schema", "event", "transaction_id"],
  "allOf": [
    {
      "$ref": "https://tracking-docs-demo.buchert.digital/constraints/schemas/firebase/v1/flat-event-params.json"
    }
  ]
}
