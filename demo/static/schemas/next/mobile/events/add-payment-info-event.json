{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tracking-docs-demo.buchert.digital/schemas/mobile/events/add-payment-info-event.json",
  "title": "Add Payment Info Event",
  "description": "Triggered when a user submits payment information in checkout.",
  "x-tracking-targets": [
    "android-firebase-kotlin-sdk",
    "android-firebase-java-sdk",
    "ios-firebase-swift-sdk",
    "ios-firebase-objc-sdk"
  ],
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Defines the structure of the event.",
      "const": "https://tracking-docs-demo.buchert.digital/schemas/mobile/events/add-payment-info-event.json"
    },
    "event": {
      "type": "string",
      "const": "add_payment_info",
      "description": "The event name add_payment_info."
    },
    "ecommerce": {
      "type": "object",
      "description": "Ecommerce payload for this event.",
      "properties": {
        "currency": {
          "type": "string",
          "description": "ISO 4217 currency code.",
          "minLength": 3,
          "maxLength": 3,
          "examples": [
            "USD"
          ]
        },
        "value": {
          "type": "number",
          "description": "Monetary value of the event.",
          "examples": [
            72.05
          ]
        },
        "coupon": {
          "type": "string",
          "description": "Coupon code associated with the event.",
          "examples": [
            "SUMMER_FUN"
          ]
        },
        "payment_type": {
          "type": "string",
          "description": "Selected payment type.",
          "examples": [
            "Credit Card"
          ]
        },
        "items": {
          "type": "array",
          "description": "Items associated with this ecommerce event.",
          "minItems": 1,
          "items": {
            "$ref": "../../events/components/product.json"
          }
        }
      },
      "required": [
        "currency",
        "items"
      ]
    }
  },
  "required": [
    "$schema",
    "event"
  ]
}
