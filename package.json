{
  "name": "tracking-docs",
  "version": "1.1.0",
  "private": true,
  "license": "MIT",
  "workspaces": [
    "packages/*",
    "demo"
  ],
  "scripts": {
    "start": "npm run start -w demo",
    "build": "npm run build -w demo",
    "gen-docs": "npm run gen-docs -w demo",
    "validate-schemas": "npm run validate-schemas -w demo",
    "update-schema-ids": "npm run update-schema-ids -w demo",
    "version": "npm run version -w demo",
    "lint": "eslint .",
    "prepare": "husky",
    "eslint:fix": "eslint --fix .",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:crap": "npm run test:coverage && node scripts/crap-report.js",
    "test:mutation": "stryker run",
    "test:payload": "npm run test:payload:web && npm run test:payload:android && npm run test:payload:ios",
    "test:payload:web": "jest packages/docusaurus-plugin-generate-schema-docs/__tests__/runtimePayload.web.test.js --runInBand",
    "test:payload:android": "jest packages/docusaurus-plugin-generate-schema-docs/__tests__/runtimePayload.android.test.js --runInBand",
    "test:payload:ios": "jest packages/docusaurus-plugin-generate-schema-docs/__tests__/runtimePayload.ios.test.js --runInBand",
    "sync:native-fixtures": "node scripts/sync-native-fixtures.mjs",
    "check:native-fixtures": "npm run sync:native-fixtures && git diff --exit-code -- native-tests/ios/Sources/NativePayloadFixtures/GeneratedSnippets.swift native-tests/ios/Sources/NativePayloadFixturesObjC/include/GeneratedObjCSnippets.h native-tests/ios/Sources/NativePayloadFixturesObjC/GeneratedObjCSnippets.m native-tests/android/src/test/java/com/trackingdocs/nativepayload/GeneratedAndroidSnippets.java native-tests/android/src/test/kotlin/com/trackingdocs/nativepayloadkotlin/GeneratedAndroidKotlinSnippets.kt",
    "pretest:native": "npm run sync:native-fixtures",
    "test:native": "npm run test:native:android && npm run test:native:ios",
    "test:native:android": "mvn -q -f native-tests/android/pom.xml test",
    "test:native:ios": "swift test --package-path native-tests/ios",
    "test:realsdk": "npm run test:realsdk:android && npm run test:realsdk:ios",
    "test:realsdk:android": "node scripts/test-android-realsdk.mjs",
    "test:realsdk:ios": "swift test --package-path native-tests/ios-sdk",
    "check:deps": "node scripts/check-dependency-specs.mjs",
    "prettier": "prettier --write .",
    "sync:gtm": "npm run sync-gtm -w demo"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/eslint-parser": "^7.28.5",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.24.0",
    "@docusaurus/eslint-plugin": "^3.9.2",
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/jest-runner": "^9.6.0",
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^15.0.7",
    "babel-jest": "^29.7.0",
    "babel-plugin-transform-import-meta": "^2.3.3",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.12.1",
    "eslint-plugin-json-schema-validator": "^5.5.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.0.0",
    "jest-environment-jsdom": "^30.2.0",
    "memfs": "^4.51.1",
    "prettier": "^3.7.4"
  },
  "optionalDependencies": {
    "@owntag/gtm-cli": "1.5.6"
  }
}
